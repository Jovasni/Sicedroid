<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <permission
        android:name="compose.project.sicedroid.permission.READ_DATABASE"
        android:protectionLevel="normal" />
    <permission
        android:name="compose.project.sicedroid.permission.WRITE_DATABASE"
        android:protectionLevel="normal" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sicedroid">

        <provider
            android:name=".data.local.SicenetContentProvider"
            android:authorities="compose.project.sicedroid.provider"
            android:exported="true"
            android:readPermission="compose.project.sicedroid.permission.READ_DATABASE"
            android:writePermission="compose.project.sicedroid.permission.WRITE_DATABASE" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Sicedroid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>